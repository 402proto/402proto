      "headers": {
        "x-402proto-version": "0.1",
        "x-402proto-client": "proto402-router/0.1.0",
        "x-402proto-wallet": "7xKp1HCNNeF9xUg5dM4PdJzQ5R8fY3MtPbE2WLwK9mT4",
