{
  "name": "@402proto/sdk",
  "version": "0.2.0-dev",
  "description": "402proto typescript client — open payment protocol for paid apis, settled in usdc on solana",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/402proto/402proto.git",
    "directory": "sdk-ts"
  },
  "homepage": "https://402proto.xyz",
  "bugs": "https://github.com/402proto/402proto/issues",
  "keywords": [
    "402proto",
    "http-402",
    "payment",
    "solana",
    "usdc",
    "agent",
    "mcp"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "module": "dist/index.mjs",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test --import tsx src/**/*.test.ts",
    "format": "prettier --write src",
    "lint": "tsc --noEmit && prettier --check src"
  },
  "dependencies": {
    "bs58": "^6.0.0",
    "@noble/curves": "^1.4.0",
    "@noble/hashes": "^1.4.0"
  },
  "peerDependencies": {
    "@solana/web3.js": "^1.95.0",
    "@solana/spl-token": "^0.4.0"
  },
  "peerDependenciesMeta": {
    "@solana/web3.js": { "optional": true },
    "@solana/spl-token": { "optional": true }
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "tsx": "^4.7.0",
    "prettier": "^3.2.0",
    "@types/node": "^20.11.0"
  }
}
