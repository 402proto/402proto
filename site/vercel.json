{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(), payment=(), usb=()" }
      ]
    },
    {
      "source": "/(.*)\\.(png|jpg|jpeg|webp|svg|ico|woff2)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "redirects": [
    { "source": "/docs", "destination": "/Docs.html", "permanent": true },
    { "source": "/platform", "destination": "/Platform.html", "permanent": true },
    { "source": "/pricing", "destination": "/Pricing.html", "permanent": true },
    { "source": "/solutions", "destination": "/Solution.html", "permanent": true },
    { "source": "/solution", "destination": "/Solution.html", "permanent": true },
    { "source": "/enterprise", "destination": "/Enterprise.html", "permanent": true },
    { "source": "/login", "destination": "/Login.html", "permanent": true },
    { "source": "/dashboard", "destination": "/Dashboard.html", "permanent": true },
    { "source": "/privacy", "destination": "/Privacy.html", "permanent": true },
    { "source": "/terms", "destination": "/Terms.html", "permanent": true },
    { "source": "/github", "destination": "https://github.com/402proto/402proto", "permanent": false },
    { "source": "/twitter", "destination": "https://x.com/x402proto", "permanent": false },
    { "source": "/x", "destination": "https://x.com/x402proto", "permanent": false }
  ]
}
